{
  "name": "composer-markdown-editor",
  "version": "1.0.0",
  "description": "A Markdown editor with local/remote directory management",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:linux": "electron-vite dev --noSandbox -- --ozone-platform=x11 --disable-gpu --disable-software-rasterizer --disable-accelerated-video-decode --disable-accelerated-video-encode --disable-features=VaapiVideoDecoder,VaapiVideoEncoder,VaapiVideoDecodeLinuxGL",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "preview:linux": "electron-vite preview --noSandbox",
    "dist": "npm run build && electron-builder",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "keywords": [
    "electron",
    "markdown",
    "editor"
  ],
  "author": "lph12168x",
  "license": "ISC",
  "devDependencies": {
    "@types/dompurify": "^3.2.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ssh2": "^1.15.5",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.0",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.3",
    "vite": "^5.4.21"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@milkdown/core": "^7.21.2",
    "@milkdown/crepe": "^7.21.2",
    "@milkdown/ctx": "^7.21.2",
    "@milkdown/prose": "^7.21.2",
    "@milkdown/react": "^7.21.2",
    "codemirror": "^6.0.2",
    "dompurify": "^3.4.11",
    "electron-store": "^11.0.2",
    "lucide-react": "^1.20.0",
    "markdown-it": "^14.2.0",
    "mermaid": "^11.15.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "simple-git": "^3.36.0",
    "ssh2": "^1.17.0",
    "zustand": "^5.0.14"
  }
}
